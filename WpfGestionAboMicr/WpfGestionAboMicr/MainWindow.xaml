<Window x:Class="WpfGestionAboMicr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:chart="clr-namespace:Syncfusion.UI.Xaml.Charts;assembly=Syncfusion.SfChart.WPF"
        xmlns:uc="clr-namespace:WpfGestionAboMicr.UserControls"
        xmlns:pg="clr-namespace:WpfGestionAboMicr.UserControls.Vue"
        mc:Ignorable="d"
        Title="MainWindow" Height="720" Width="1280"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <!-- Style réutilisable -->
    <Window.Resources>

    </Window.Resources>
    <Grid>
        <!--#region Menu latéral -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="175*" MaxWidth="250"/>
            <ColumnDefinition Width="673*"/>
        </Grid.ColumnDefinitions>

        <uc:MenuTemplate x:Name="MonMenu"
                         HeaderMenu="Menu"
                         Version="v1.0.0"
                         AppName="Mock"
                         NavigationRequested="MonMenu_NavigationRequested"/>
        <!--#endregion-->

        <Grid Grid.Column="1" x:Name="conteneur">
        </Grid>
            

    </Grid>

</Window>

