<UserControl x:Class="WpfGestionAboMicr.UserControls.Vue.DetailClient"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:syncfgrid="clr-namespace:Syncfusion.UI.Xaml.Grid;assembly=Syncfusion.SfGrid.WPF"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F5F7FA">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- BARRE D'ACTIONS -->
        <Border Grid.Row="0"
                Background="White" BorderBrush="#E5E7EB"
                BorderThickness="1" CornerRadius="8" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BtnEnregistrer"
                            Content="💾 Enregistrer"
                            IsEnabled="False"
                            Padding="14,6" Margin="0,0,8,0"
                            Background="#1D4ED8" Foreground="White"
                            BorderThickness="0"
                            Click="BtnEnregistrer_Click"/>

                    <Button x:Name="BtnActualiser"
                            Content="↺ Actualiser"
                            Padding="14,6" Margin="0,0,8,0"
                            Background="#6B7280" Foreground="White"
                            BorderThickness="0"
                            Click="BtnActualiser_Click"/>

                    <Button x:Name="BtnImprimer"
                            Content="🖨 Imprimer"
                            Padding="14,6"
                            Background="#6B7280" Foreground="White"
                            BorderThickness="0"
                            Click="BtnImprimer_Click"/>
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="BtnRetour"
                        Content="← Retour"
                        Padding="14,6"
                        Background="Transparent" Foreground="#374151"
                        BorderThickness="0" FontWeight="SemiBold"
                        Click="BtnRetour_Click"/>
            </Grid>
        </Border>

        <!-- EN-TÊTE CLIENT -->
        <Border Grid.Row="2"
                Background="White" CornerRadius="8"
                Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Ligne 1 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Client" FontSize="11"
                                   Foreground="#9CA3AF" Margin="2,0,0,2"/>
                        <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="20" FontWeight="Bold"
                                 BorderThickness="0,0,0,1" BorderBrush="#E5E7EB"
                                 Background="Transparent"
                                 TextChanged="OnClientChampModifie"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding Id, StringFormat=Id : {0}}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#4B5563" FontWeight="SemiBold"/>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="État facturation" FontSize="11"
                                   Foreground="#9CA3AF" Margin="2,0,0,2"/>
                        <ComboBox x:Name="CboEtatFacturation"
                                  SelectedItem="{Binding EtatFacturation, Mode=TwoWay}"
                                  Height="32"
                                  SelectionChanged="OnClientChampModifie_Combo">
                            <sys:String>AJour</sys:String>
                            <sys:String>EnAttente</sys:String>
                            <sys:String>EnRetard</sys:String>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Ligne 2 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,0"
                                 BorderThickness="0,0,0,1" BorderBrush="#E5E7EB"
                                 Background="Transparent"
                                 TextChanged="OnClientChampModifie"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Téléphone" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBox Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,0"
                                 BorderThickness="0,0,0,1" BorderBrush="#E5E7EB"
                                 Background="Transparent"
                                 Tag="telephone"
                                 PreviewTextInput="TxtNumerique_PreviewTextInput"
                                 TextChanged="TxtNumerique_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Contact principal" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBox Text="{Binding ContactPrincipal, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,0"
                                 BorderThickness="0,0,0,1" BorderBrush="#E5E7EB"
                                 Background="Transparent"
                                 TextChanged="OnClientChampModifie"/>
                    </StackPanel>
                </Grid>

                <!-- Ligne 3 -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Adresse" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBox Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,0"
                                 BorderThickness="0,0,0,1" BorderBrush="#E5E7EB"
                                 Background="Transparent"
                                 TextWrapping="Wrap"
                                 TextChanged="OnClientChampModifie"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Prochain renouvellement" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBox Text="{Binding ProchainRenouvellement}"
                                 Margin="0,4,0,0"
                                 BorderThickness="0,0,0,1"
                                 BorderBrush="#E5E7EB"
                                 Background="#F9FAFB"
                                 IsReadOnly="True"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ONGLETS -->
        <TabControl Grid.Row="4"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

            <!-- Abonnements -->
            <TabItem Header="Abonnements">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Button x:Name="BtnAjouterAbonnement"
                                Content="+ Ajouter un abonnement"
                                Padding="12,6" Margin="0,0,8,0"
                                Background="Transparent" Foreground="#1D4ED8"
                                BorderThickness="0" FontWeight="SemiBold"
                                Click="BtnAjouterAbonnement_Click"/>

                        <Button x:Name="BtnSupprimerAbonnement"
                                Content="🗑 Supprimer"
                                Padding="12,6"
                                Background="Transparent" Foreground="#DC2626"
                                BorderThickness="0" FontWeight="SemiBold"
                                Click="BtnSupprimerAbonnement_Click"/>
                    </StackPanel>

                    <syncfgrid:SfDataGrid Grid.Row="2"
                                          x:Name="AbonnementsGrid"
                                          AutoGenerateColumns="False"
                                          ColumnSizer="Star"
                                          AllowEditing="True"
                                          NavigationMode="Cell">
                        <syncfgrid:SfDataGrid.Columns>

                            <syncfgrid:GridComboBoxColumn MappingName="TypeAbonnement"
                                                          HeaderText="Produit"
                                                          IsReadOnly="False">
                                <syncfgrid:GridComboBoxColumn.ItemsSource>
                                    <x:Array Type="{x:Type sys:String}">
                                        <sys:String>Microsoft 365 Business Basic</sys:String>
                                        <sys:String>Microsoft 365 Business Standard</sys:String>
                                        <sys:String>Microsoft 365 Business Premium</sys:String>
                                        <sys:String>Microsoft 365 E3</sys:String>
                                        <sys:String>Microsoft 365 E5</sys:String>
                                    </x:Array>
                                </syncfgrid:GridComboBoxColumn.ItemsSource>
                            </syncfgrid:GridComboBoxColumn>

                            <syncfgrid:GridNumericColumn MappingName="Quantite"
                                                         HeaderText="Quantité"
                                                         NumberDecimalDigits="0"
                                                         IsReadOnly="False"/>

                            <syncfgrid:GridTextColumn MappingName="DateDebut"
                                                      HeaderText="Date début"
                                                      IsReadOnly="True"/>

                            <syncfgrid:GridTextColumn MappingName="DateFin"
                                                      HeaderText="Date fin"
                                                      IsReadOnly="True"/>

                            <syncfgrid:GridTextColumn MappingName="ProchainRenouvellement"
                                                      HeaderText="Prochain renouvellement"
                                                      IsReadOnly="True"/>

                            <syncfgrid:GridComboBoxColumn MappingName="Statut"
                                                          HeaderText="Statut"
                                                          IsReadOnly="False">
                                <syncfgrid:GridComboBoxColumn.ItemsSource>
                                    <x:Array Type="{x:Type sys:String}">
                                        <sys:String>Actif</sys:String>
                                        <sys:String>Expiré</sys:String>
                                        <sys:String>EnAttente</sys:String>
                                    </x:Array>
                                </syncfgrid:GridComboBoxColumn.ItemsSource>
                            </syncfgrid:GridComboBoxColumn>

                        </syncfgrid:SfDataGrid.Columns>
                    </syncfgrid:SfDataGrid>

                    <TextBlock Grid.Row="3"
                               Foreground="#9CA3AF"
                               FontStyle="Italic"
                               Margin="0,6,0,0"
                               Text="Seuls le produit, la quantité et le statut sont modifiables. Les dates sont calculées automatiquement."/>
                </Grid>
            </TabItem>

            <!-- Facturation -->
            <TabItem Header="Facturation">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <syncfgrid:SfDataGrid Grid.Row="2"
                                          x:Name="FacturationGrid"
                                          AutoGenerateColumns="False"
                                          ColumnSizer="Star"
                                          AllowEditing="False"
                                          NavigationMode="Cell">
                        <syncfgrid:SfDataGrid.Columns>
                            <syncfgrid:GridTextColumn MappingName="Numero" HeaderText="N° Facture"/>
                            <syncfgrid:GridTextColumn MappingName="Date" HeaderText="Date"/>
                            <syncfgrid:GridTextColumn MappingName="Montant" HeaderText="Montant"/>
                            <syncfgrid:GridTextColumn MappingName="Statut" HeaderText="Statut"/>
                        </syncfgrid:SfDataGrid.Columns>
                    </syncfgrid:SfDataGrid>
                </Grid>
            </TabItem>

            <!-- Historique -->
            <TabItem Header="Historique">
                <ScrollViewer Margin="16" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="HistoriqueList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F9FAFB" CornerRadius="8"
                                        BorderBrush="#E5E7EB" BorderThickness="1"
                                        Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Date}"
                                                   Foreground="#9CA3AF" FontSize="12"
                                                   VerticalAlignment="Top"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Action}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Top"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Description}"
                                                   Foreground="#6B7280" FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>