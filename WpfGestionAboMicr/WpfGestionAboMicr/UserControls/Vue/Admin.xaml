<UserControl x:Class="WpfGestionAboMicr.UserControls.Vue.Admin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfGestionAboMicr.UserControls.Vue"
             mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="🔧 Test API"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnClients"
                        Content="GET /api/clients"
                        Padding="14,8"
                        Background="#01696f"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnClients_Click"/>
                <TextBlock x:Name="TxtStatutClients"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontSize="13"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnAbonnements"
                        Content="GET /api/abonnements"
                        Padding="14,8"
                        Background="#01696f"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnAbonnements_Click"/>
                <TextBlock x:Name="TxtStatutAbonnements"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontSize="13"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnFactures"
                        Content="GET /api/factures"
                        Padding="14,8"
                        Background="#01696f"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnFactures_Click"/>
                <TextBlock x:Name="TxtStatutFactures"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontSize="13"/>
            </StackPanel>

            <Separator Margin="0,8,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnOk"
                        Content="GET /api/test/ok"
                        Padding="14,8"
                        Background="#2e7d32"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnOk_Click"/>
                <TextBlock x:Name="TxtStatutOk"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontSize="13"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnBadRequest"
                        Content="GET /api/test/badrequest"
                        Padding="14,8"
                        Background="#ef6c00"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnBadRequest_Click"/>
                <TextBlock x:Name="TxtStatutBadRequest"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontSize="13"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnNotFound"
                        Content="GET /api/test/notfound"
                        Padding="14,8"
                        Background="#c62828"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnNotFound_Click"/>
                <TextBlock x:Name="TxtStatutNotFound"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontSize="13"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnError"
                        Content="GET /api/test/error"
                        Padding="14,8"
                        Background="#6a1b9a"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnError_Click"/>
                <TextBlock x:Name="TxtStatutError"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontSize="13"/>
            </StackPanel>

        </StackPanel>

        <Border Grid.Row="2"
                Background="#1e1e1e"
                CornerRadius="6"
                Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TxtReponse"
                           Foreground="#d4d4d4"
                           FontFamily="Consolas"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>