<UserControl x:Class="WpfGestionAboMicr.UserControls.Vue.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:chart="clr-namespace:Syncfusion.UI.Xaml.Charts;assembly=Syncfusion.SfChart.WPF"
             xmlns:local="clr-namespace:WpfGestionAboMicr.UserControls.Vue"
             xmlns:uc="clr-namespace:WpfGestionAboMicr.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180">

    <UserControl.Resources>
        <local:StatutToBrushConverter x:Key="StatutToBrush"/>
        <local:TypeValeurToBrushConverter x:Key="TypeValeurToBrush"/>

        <!-- Palette -->
        <SolidColorBrush x:Key="PageBackgroundBrush"  Color="#F5F7FA"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="White"/>
        <SolidColorBrush x:Key="PanelBorderBrush"     Color="#E4E8EE"/>
        <SolidColorBrush x:Key="AccentBrush"          Color="#2E86C1"/>
        <SolidColorBrush x:Key="TitleBrush"           Color="#184A8C"/>
        <SolidColorBrush x:Key="MutedTextBrush"       Color="#6B7280"/>
        <SolidColorBrush x:Key="LightTextBrush"       Color="#9AA3AF"/>
        <SolidColorBrush x:Key="WarningBrush"         Color="#E08A00"/>

        <!-- Blocs panneaux -->
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="10"/>
        </Style>

        <!-- Titres de section -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="{DynamicResource DynamicFontSize}"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Foreground"       Value="{StaticResource TitleBrush}"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Sous-titre gris -->
        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Foreground"       Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Lien action -->
        <Style x:Key="ActionLinkStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,8,0,0"/>
        </Style>

        <!-- Cellule DataGrid plate -->
        <Style x:Key="FlatGridCellStyle" TargetType="syncfusion:GridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Padding"         Value="6,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <!-- Fond de page -->
    <Grid Background="{StaticResource PageBackgroundBrush}">

        <!-- Grille principale fluide -->
        <Grid Margin="14,0,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- KPI -->
                <RowDefinition Height="10"/>
                <!-- espace -->
                <RowDefinition Height="*"/>
                <!-- ligne 1 panneaux -->
                <RowDefinition Height="10"/>
                <!-- espace -->
                <RowDefinition Height="*"/>
                <!-- ligne 2 panneaux -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════
                 LIGNE KPI
            ═══════════════════════════════════════ -->
            <UniformGrid Grid.Row="0" Columns="4" Rows="1">
                <uc:DataCard Margin="0,0,10,0"
                             Indicateur="▲ ce mois"
                             CouleurIndicateur="{StaticResource LightTextBrush}"
                             IconeSource="/Resources/clients.png"
                             CouleurIcone="#0055FF"
                             Valeur="{Binding NombreClients}"
                             Label="Clients"/>

                <uc:DataCard Margin="0,0,10,0"
                             Indicateur="▲ ce mois"
                             CouleurIndicateur="{StaticResource LightTextBrush}"
                             IconeSource="/Resources/clientAbonnements.png"
                             CouleurIcone="#00AA55"
                             Valeur="{Binding NombreAbonnements}"
                             Label="Abonnements"/>

                <uc:DataCard Margin="0,0,10,0"
                             Indicateur="≤ 30 jours"
                             CouleurIndicateur="{StaticResource WarningBrush}"
                             IconeSource="/Resources/renouvellement.png"
                             CouleurIcone="#E08000"
                             Valeur="{Binding NombreRenouvellements}"
                             Label="À renouveler"/>

                <uc:DataCard Indicateur="À traiter"
                             CouleurIndicateur="{StaticResource LightTextBrush}"
                             IconeSource="/Resources/facturation.png"
                             CouleurIcone="#7B2FBE"
                             Valeur="{Binding NombreFacturesEnAttente}"
                             Label="Factures en attente"/>
            </UniformGrid>

            <!-- ═══════════════════════════════════════
                 LIGNE 1 — Donut + Renouvellements
            ═══════════════════════════════════════ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <!-- Donut -->
                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- En-tête -->
                        <Grid Grid.Row="0" Margin="18,14,18,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Abonnements par produit"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Répartition actuelle"
                                       Style="{StaticResource SectionHintStyle}"
                                       Margin="8,2,0,0"/>
                        </Grid>

                        <!-- Graphique -->
                        <chart:SfChart Grid.Row="1"
                                       Margin="6,0,6,8"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch">

                            <chart:SfChart.Legend>
                                <chart:ChartLegend DockPosition="Right"
                                                   Orientation="Vertical"
                                                   CheckBoxVisibility="Collapsed"
                                                   IconWidth="12" IconHeight="12"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,14,0">
                                    <chart:ChartLegend.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                <Rectangle Width="11" Height="11"
                                                           Fill="{Binding Interior}"
                                                           Margin="0,0,7,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding Item.NombreAbos, StringFormat=({0})}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding Item.Percentage, StringFormat={}{0:F1}%}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </chart:ChartLegend.ItemTemplate>
                                </chart:ChartLegend>
                            </chart:SfChart.Legend>

                            <chart:DoughnutSeries ItemsSource="{Binding DataEvolution}"
                                                  XBindingPath="TypeAbonnement"
                                                  YBindingPath="NombreAbos"
                                                  DoughnutSize="0.76"
                                                  Palette="Custom"
                                                  LegendIcon="Circle"
                                                  ExplodeOnMouseClick="True"
                                                  ExplodeRadius="8"
                                                  Margin="0,0,0,8">
                                <chart:DoughnutSeries.ColorModel>
                                    <chart:ChartColorModel>
                                        <chart:ChartColorModel.CustomBrushes>
                                            <SolidColorBrush Color="#D4913A"/>
                                            <SolidColorBrush Color="#2E8DC0"/>
                                            <SolidColorBrush Color="#374657"/>
                                            <SolidColorBrush Color="#CDD0DA"/>
                                            <SolidColorBrush Color="#B8956A"/>
                                        </chart:ChartColorModel.CustomBrushes>
                                    </chart:ChartColorModel>
                                </chart:DoughnutSeries.ColorModel>
                            </chart:DoughnutSeries>
                        </chart:SfChart>
                    </Grid>
                </Border>

                <!-- Renouvellements -->
                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                    <Grid Margin="18,14,18,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prochains renouvellements"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Vue rapide"
                                       Style="{StaticResource SectionHintStyle}"
                                       Margin="8,2,0,0"/>
                        </Grid>

                        <syncfusion:SfDataGrid Grid.Row="1"
                                               x:Name="MonDataGrid"
                                               AutoGenerateColumns="False"
                                               ItemsSource="{Binding ListeRenouvellements}"
                                               ColumnSizer="Star"
                                               HeaderRowHeight="0"
                                               RowHeight="38"
                                               BorderThickness="0"
                                               GridLinesVisibility="None"
                                               AllowSorting="False"
                                               Background="Transparent"
                                               SelectionMode="None"
                                               Margin="0,4,0,0">
                            <syncfusion:SfDataGrid.Resources>
                                <Style TargetType="syncfusion:GridCell"
                                       BasedOn="{StaticResource FlatGridCellStyle}"/>
                            </syncfusion:SfDataGrid.Resources>
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTemplateColumn MappingName="Client">
                                    <syncfusion:GridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Client}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </syncfusion:GridTemplateColumn.CellTemplate>
                                </syncfusion:GridTemplateColumn>
                                <syncfusion:GridTemplateColumn MappingName="DateRenouvellement" Width="115">
                                    <syncfusion:GridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DateRenouvellement}"
                                                       Foreground="{Binding Statut, Converter={StaticResource StatutToBrush}}"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </syncfusion:GridTemplateColumn.CellTemplate>
                                </syncfusion:GridTemplateColumn>
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>

                        <TextBlock Grid.Row="2" Style="{StaticResource ActionLinkStyle}">
                            <Hyperlink Foreground="{StaticResource AccentBrush}"
                                       TextDecorations="{x:Null}">
                                Voir tous les renouvellements
                            </Hyperlink>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════
                 LIGNE 2 — Évolution + Résumé financier
            ═══════════════════════════════════════ -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <!-- Évolution -->
                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="18,14,18,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Évolution des abonnements"
                                       Style="{StaticResource SectionTitleStyle}"/>

                        </Grid>

                        <chart:SfChart Grid.Row="1"
                                       Margin="10,0,10,10"
                                       Padding="6">
                            <chart:SfChart.Resources>
                                <DataTemplate x:Key="CircleMarkerTemplate">
                                    <Ellipse x:Name="EllipseGraph"
                                             Width="12" Height="12"
                                             Fill="White"
                                             Stroke="{StaticResource AccentBrush}"
                                             StrokeThickness="2"/>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="EllipseGraph" Property="Fill"   Value="{StaticResource AccentBrush}"/>
                                            <Setter TargetName="EllipseGraph" Property="Width"  Value="16"/>
                                            <Setter TargetName="EllipseGraph" Property="Height" Value="16"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </chart:SfChart.Resources>

                            <chart:SfChart.PrimaryAxis>
                                <chart:CategoryAxis EdgeLabelsDrawingMode="Fit">
                                    <chart:CategoryAxis.MajorGridLineStyle>
                                        <Style TargetType="Line">
                                            <Setter Property="StrokeThickness" Value="0"/>
                                        </Style>
                                    </chart:CategoryAxis.MajorGridLineStyle>
                                </chart:CategoryAxis>
                            </chart:SfChart.PrimaryAxis>

                            <chart:SfChart.SecondaryAxis>
                                <chart:NumericalAxis Minimum="0"
                                                     Interval="10"
                                                     RangePadding="Auto">
                                    <chart:NumericalAxis.MajorGridLineStyle>
                                        <Style TargetType="Line">
                                            <Setter Property="Stroke"          Value="#D9DEE7"/>
                                            <Setter Property="StrokeThickness" Value="0.8"/>
                                        </Style>
                                    </chart:NumericalAxis.MajorGridLineStyle>
                                </chart:NumericalAxis>
                            </chart:SfChart.SecondaryAxis>

                            <chart:LineSeries ItemsSource="{Binding EvolutionModel}"
                                              XBindingPath="Mois"
                                              YBindingPath="NombreAbos"
                                              Interior="{StaticResource AccentBrush}"
                                              StrokeThickness="2.5">
                                <chart:LineSeries.AdornmentsInfo>
                                    <chart:ChartAdornmentInfo ShowMarker="True"
                                                              SymbolTemplate="{StaticResource CircleMarkerTemplate}"/>
                                </chart:LineSeries.AdornmentsInfo>
                            </chart:LineSeries>
                        </chart:SfChart>
                    </Grid>
                </Border>

                <!-- Résumé financier -->
                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                    <Grid Margin="18,14,18,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Résumé financier"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Ce mois"
                                       Style="{StaticResource SectionHintStyle}"
                                       Margin="8,2,0,0"/>
                        </Grid>

                        <syncfusion:SfDataGrid Grid.Row="1"
                                               x:Name="GridResume"
                                               AutoGenerateColumns="False"
                                               ItemsSource="{Binding ListeResume}"
                                               ColumnSizer="Star"
                                               HeaderRowHeight="0"
                                               RowHeight="40"
                                               BorderThickness="0"
                                               GridLinesVisibility="None"
                                               AllowSorting="False"
                                               Background="Transparent"
                                               SelectionMode="None"
                                               Margin="0,6,0,0">
                            <syncfusion:SfDataGrid.Resources>
                                <Style TargetType="syncfusion:GridCell"
                                       BasedOn="{StaticResource FlatGridCellStyle}"/>
                            </syncfusion:SfDataGrid.Resources>
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTemplateColumn MappingName="Label">
                                    <syncfusion:GridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </syncfusion:GridTemplateColumn.CellTemplate>
                                </syncfusion:GridTemplateColumn>
                                <syncfusion:GridTemplateColumn MappingName="Valeur" Width="115">
                                    <syncfusion:GridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Valeur}"
                                                       Foreground="{Binding TypeValeur, Converter={StaticResource TypeValeurToBrush}}"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </syncfusion:GridTemplateColumn.CellTemplate>
                                </syncfusion:GridTemplateColumn>
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</UserControl>