<UserControl x:Class="WpfGestionAboMicr.UserControls.Vue.Clients"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:local="clr-namespace:WpfGestionAboMicr.UserControls.Vue"
             Background="#F5F7FA"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="HeaderCenterTextStyle" TargetType="syncfusion:GridHeaderCellControl">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <local:EtatFacturationToBrushConverter x:Key="EtatFacturationToBrushConverter"/>
    </UserControl.Resources>

    <Grid Background="#F5F7FA" Margin="12">
        <Border Background="White"
                CornerRadius="8"
                Padding="16"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- En-tête -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <TextBlock Text="Liste des clients"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left"/>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBox x:Name="TxtRecherche"
                                 Width="220" Height="30"
                                 Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtRecherche_TextChanged"/>

                        <Button x:Name="BtnActualiser"
                                Content="↺ Actualiser"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="#6B7280" Foreground="White"
                                BorderThickness="0"
                                Click="BtnActualiser_Click"/>
                        <Button x:Name="BtnAjouter"
                                Content="+ Ajouter"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="Transparent" Foreground="#1D4ED8"
                                BorderThickness="0" FontWeight="SemiBold"
                                Click="BtnNouveau_Click"/>
                        <Button x:Name="BtnSupprimer"
                                Content="🗑 Supprimer"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="Transparent" Foreground="#DC2626"
                                BorderThickness="0" FontWeight="SemiBold"
                                Click="BtnSupprimer_Click"/>
                    </StackPanel>
                </DockPanel>

                <!-- DataGrid lié au PagedSource du pager -->
                <syncfusion:SfDataGrid Grid.Row="2"
                                       x:Name="ClientsGrid"
                                       AutoGenerateColumns="False"
                                       AllowSorting="False"
                                       AllowFiltering="False"
                                       SelectionMode="Single"
                                       NavigationMode="Row"
                                       RowHeight="38"
                                       HeaderRowHeight="40"
                                       ColumnSizer="Star"
                                       ItemsSource="{Binding ElementName=DataPager, Path=PagedSource}"
                                       MouseDoubleClick="ClientsGrid_MouseDoubleClick">

                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn MappingName="Id"
                                                   HeaderText="Id"
                                                   Width="70"
                                                   TextAlignment="Center"/>

                        <syncfusion:GridTextColumn MappingName="Nom"
                                                   HeaderText="Nom Client"/>

                        <syncfusion:GridTextColumn MappingName="Email"
                                                   HeaderText="Email"/>

                        <syncfusion:GridTextColumn MappingName="Telephone"
                                                   HeaderText="Téléphone"
                                                   TextAlignment="Center"/>

                        <!-- GridNumericColumn pour éviter la couleur bleue de lien -->
                        <syncfusion:GridNumericColumn MappingName="NombreAbonnements"
                                                      HeaderText="Nb Abonnements"
                                                      TextAlignment="Center"
                                                      NumberDecimalDigits="0"/>

                        <syncfusion:GridTemplateColumn HeaderText="État Facturation"
                                                       MappingName="EtatFacturation">
                            <syncfusion:GridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding EtatFacturation}"
                                               Foreground="{Binding EtatFacturation, Converter={StaticResource EtatFacturationToBrushConverter}}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </syncfusion:GridTemplateColumn.CellTemplate>
                        </syncfusion:GridTemplateColumn>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <!-- SfDataPager natif Syncfusion -->
                <!-- Barre bas : éléments par page + pager -->
                <DockPanel Grid.Row="3" LastChildFill="True" Margin="0,8,0,0">

                    <!-- Éléments par page -->
                    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                DockPanel.Dock="Left"
                Margin="0,0,12,0">
                        <TextBlock Text="Éléments par page"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="CboElementsParPage"
                  Width="70" Height="28"
                  VerticalAlignment="Center"
                  SelectionChanged="CboElementsParPage_SelectionChanged"/>
                    </StackPanel>

                    <!-- SfDataPager -->
                    <syncfusion:SfDataPager x:Name="DataPager"
                            PageSize="10"
                            NumericButtonCount="5"
                            UseOnDemandPaging="False"
                            PageIndexChanged="DataPager_PageIndexChanged"
                            DockPanel.Dock="Right"/>

                    <!-- Texte pagination centré -->
                    <TextBlock x:Name="TxtPagination"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Foreground="#4B5563"
               FontSize="13"/>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>