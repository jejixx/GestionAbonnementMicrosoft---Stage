<UserControl x:Class="WpfGestionAboMicr.UserControls.Vue.Facturation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:local="clr-namespace:WpfGestionAboMicr.UserControls.Vue"
             Background="#F3F4F6">

    <UserControl.Resources>
        <local:StatutColorConverter x:Key="StatutColor"/>
        <DataTemplate x:Key="StatutTemplate">
            <TextBlock Text="{Binding Statut}"
                       Foreground="{Binding Statut, Converter={StaticResource StatutColor}}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="4,0"/>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel Margin="12" LastChildFill="True">

        <!-- ═══ BARRE HAUT ═══ -->
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,10">
            <DockPanel LastChildFill="False">

                <TextBlock Text="Facturation"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">

                    <TextBox x:Name="TxtRecherche"
                             Width="220"
                             Height="30"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             TextChanged="TxtRecherche_TextChanged"/>

                    <Button x:Name="BtnExporter"
                            Content="📤 Exporter"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Background="#0F766E"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnExporter_Click"/>

                    <Button x:Name="BtnSauvegarder"
                            Content="💾 Enregistrer"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Background="#1D4ED8"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnSauvegarder_Click"/>

                    <Button x:Name="BtnActualiser"
                            Content="↺ Actualiser"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Background="#6B7280"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnActualiser_Click"/>

                    <Button x:Name="BtnNouveau"
                            Content="+ Ajouter"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            Foreground="#1D4ED8"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="BtnNouveau_Click"/>

                    <Button x:Name="BtnAnnuler"
                            Content="✕ Annuler"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Background="Transparent"
                            Foreground="#DC2626"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="BtnAnnuler_Click"/>

                    <Button x:Name="BtnMarquerPaye"
                            Content="✔ Marquer comme payée"
                            Padding="14,6"
                            Background="#059669"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnMarquerPaye_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ DÉTAIL BAS ═══ -->
        <Border DockPanel.Dock="Bottom"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Détail facture"
                           FontWeight="SemiBold"
                           FontSize="14"/>

                <!-- Ligne 1 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LblTiers"
                                   Text="Client"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <ComboBox x:Name="CboTiers"
                                  Height="30"
                                  IsEditable="False"
                                  IsEnabled="False"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Nfacture"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtNumero"
                                 Height="30"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Date"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtDate"
                                 Height="30"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Échéance"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtEcheance"
                                 Height="30"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"/>
                    </StackPanel>
                </Grid>

                <!-- Ligne 2 -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Montant HT"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtMontantHT"
                                 Height="30"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TVA"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtTVA"
                                 Height="30"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Montant TTC"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtMontantTTC"
                                 Height="30"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Mode de paiement"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <ComboBox x:Name="CboModePaiement"
                                  Height="30"
                                  IsEnabled="False">
                            <ComboBoxItem Content="Virement"/>
                            <ComboBoxItem Content="CB"/>
                            <ComboBoxItem Content="Prélèvement"/>
                            <ComboBoxItem Content="Espèces"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Ligne 3 -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Date de paiement"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtDatePaiement"
                                 Height="30"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Statut"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,0,0,3"/>
                        <ComboBox x:Name="CboStatut"
                                  Height="30"
                                  IsEnabled="False">
                            <ComboBoxItem Content="Payée"/>
                            <ComboBoxItem Content="EnAttente"/>
                            <ComboBoxItem Content="EnRetard"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Ligne 4 -->
                <StackPanel Grid.Row="8">
                    <TextBlock Text="Note"
                               Foreground="#555"
                               FontSize="11"
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtNote"
                             Height="50"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="6,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TABLEAU CENTRE ═══ -->
        <Border Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- headers onglets -->
                    <RowDefinition Height="*"/>
                    <!-- ← grille prend tout l'espace restant -->
                </Grid.RowDefinitions>

                <!-- ✅ TabControl en Row="1" (hauteur *) -->
                <TabControl Grid.Row="1"
                            x:Name="TabFactures"
                            BorderThickness="0"
                            Background="Transparent"
                            SelectionChanged="TabFactures_SelectionChanged">

                    <TabItem Header="Factures client">
                        <!-- ✅ Pas de Grid.Row ici, TabItem n'est pas un Grid -->
                        <syncfusion:SfDataGrid x:Name="GridClients"
                                               AutoGenerateColumns="False"
                                               AllowEditing="False"
                                               AllowSorting="True"
                                               SelectionMode="Single"
                                               NavigationMode="Row"
                                               ColumnSizer="Star"
                                               HeaderRowHeight="34"
                                               RowHeight="32"
                                               GridLinesVisibility="Both"
                                               SelectionChanged="GridClients_SelectionChanged">
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTextColumn MappingName="Numero"       HeaderText="Nfacture"/>
                                <syncfusion:GridTextColumn MappingName="Client"       HeaderText="Client"/>
                                <syncfusion:GridTextColumn MappingName="Date"         HeaderText="Date"/>
                                <syncfusion:GridTextColumn MappingName="DateEcheance" HeaderText="Échéance"/>
                                <syncfusion:GridTextColumn MappingName="MontantHT"    HeaderText="Montant HT"/>
                                <syncfusion:GridTextColumn MappingName="TVA"          HeaderText="TVA"/>
                                <syncfusion:GridTextColumn MappingName="MontantTTC"   HeaderText="Montant TTC"/>
                                <syncfusion:GridTemplateColumn MappingName="Statut"
                                                               HeaderText="Statut"
                                                               CellTemplate="{StaticResource StatutTemplate}"/>
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>
                    </TabItem>

                    <TabItem Header="Factures fournisseurs">
                        <!-- ✅ Pas de Grid.Row ici non plus -->
                        <syncfusion:SfDataGrid x:Name="GridFourn"
                                               AutoGenerateColumns="False"
                                               AllowEditing="False"
                                               AllowSorting="True"
                                               SelectionMode="Single"
                                               NavigationMode="Row"
                                               ColumnSizer="Star"
                                               HeaderRowHeight="34"
                                               RowHeight="32"
                                               GridLinesVisibility="Both"
                                               SelectionChanged="GridFourn_SelectionChanged">
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTextColumn MappingName="Numero"       HeaderText="Nfacture"/>
                                <syncfusion:GridTextColumn MappingName="Fournisseur"  HeaderText="Fournisseur"/>
                                <syncfusion:GridTextColumn MappingName="Date"         HeaderText="Date"/>
                                <syncfusion:GridTextColumn MappingName="DateEcheance" HeaderText="Échéance"/>
                                <syncfusion:GridTextColumn MappingName="MontantHT"    HeaderText="Montant HT"/>
                                <syncfusion:GridTextColumn MappingName="TVA"          HeaderText="TVA"/>
                                <syncfusion:GridTextColumn MappingName="MontantTTC"   HeaderText="Montant TTC"/>
                                <syncfusion:GridTemplateColumn MappingName="Statut"
                                                               HeaderText="Statut"
                                                               CellTemplate="{StaticResource StatutTemplate}"/>
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>

    </DockPanel>
</UserControl>