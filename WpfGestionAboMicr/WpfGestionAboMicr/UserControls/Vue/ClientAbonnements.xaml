<UserControl x:Class="WpfGestionAboMicr.UserControls.Vue.ClientAbonnements"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F5F7FA">

    <Grid Margin="12">
        <Border Background="White" CornerRadius="8" Padding="16"
                BorderBrush="#E5E7EB" BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- EN-TÊTE + ACTIONS -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <TextBlock Text="Client Abonnements"
                               FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left"/>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBox x:Name="TxtRecherche"
                                 Width="220" Height="30"
                                 Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtRecherche_TextChanged"/>

                        <Button x:Name="BtnEnregistrer"
                                Content="💾 Enregistrer"
                                IsEnabled="False"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="#1D4ED8" Foreground="White"
                                BorderThickness="0"
                                Click="BtnEnregistrer_Click"/>

                        <Button x:Name="BtnActualiser"
                                Content="↺ Actualiser"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="#6B7280" Foreground="White"
                                BorderThickness="0"
                                Click="BtnActualiser_Click"/>

                        <Button x:Name="BtnAjouter"
                                Content="+ Ajouter"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="Transparent" Foreground="#1D4ED8"
                                BorderThickness="0" FontWeight="SemiBold"
                                Click="BtnAjouter_Click"/>

                        <Button x:Name="BtnSupprimer"
                                Content="🗑 Supprimer"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="Transparent" Foreground="#DC2626"
                                BorderThickness="0" FontWeight="SemiBold"
                                Click="BtnSupprimer_Click"/>
                    </StackPanel>
                </DockPanel>

                <!-- GRILLE -->
                <syncfusion:SfDataGrid Grid.Row="2"
                                       x:Name="AbonnementsGrid"
                                       AutoGenerateColumns="False"
                                       ColumnSizer="Star"
                                       AllowEditing="True"
                                       AllowSorting="True"
                                       NavigationMode="Cell"
                                       SelectionMode="Single"
                                       RowHeight="38"
                                       HeaderRowHeight="40"
                                       ItemsSource="{Binding ElementName=DataPager, Path=PagedSource}"
                                       CurrentCellEndEdit="AbonnementsGrid_CurrentCellEndEdit">

                    <syncfusion:SfDataGrid.Columns>

                        <syncfusion:GridTextColumn MappingName="Id"
                                                   HeaderText="Id"
                                                   IsReadOnly="True"
                                                   Width="60"
                                                   TextAlignment="Center"/>

                        <syncfusion:GridComboBoxColumn x:Name="ColClient"
                                                       MappingName="ClientId"
                                                       HeaderText="Client"
                                                       DisplayMemberPath="Nom"
                                                       SelectedValuePath="Id"/>

                        <syncfusion:GridComboBoxColumn MappingName="TypeAbonnement"
                                                       HeaderText="Produit">
                            <syncfusion:GridComboBoxColumn.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>Microsoft 365 Business Basic</sys:String>
                                    <sys:String>Microsoft 365 Business Standard</sys:String>
                                    <sys:String>Microsoft 365 Business Premium</sys:String>
                                    <sys:String>Microsoft 365 E3</sys:String>
                                    <sys:String>Microsoft 365 E5</sys:String>
                                </x:Array>
                            </syncfusion:GridComboBoxColumn.ItemsSource>
                        </syncfusion:GridComboBoxColumn>

                        <syncfusion:GridNumericColumn MappingName="Quantite"
                                                      HeaderText="Quantité"
                                                      NumberDecimalDigits="0"
                                                      TextAlignment="Center"/>

                        <syncfusion:GridTextColumn MappingName="DateDebut"
                                                   HeaderText="Date début"
                                                   IsReadOnly="True"/>

                        <syncfusion:GridTextColumn MappingName="DateFin"
                                                   HeaderText="Date fin"
                                                   IsReadOnly="True"/>

                        <syncfusion:GridTextColumn MappingName="ProchainRenouvellement"
                                                   HeaderText="Prochain renouvellement"
                                                   IsReadOnly="True"/>

                        <syncfusion:GridComboBoxColumn MappingName="Statut"
                                                       HeaderText="Statut">
                            <syncfusion:GridComboBoxColumn.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>Actif</sys:String>
                                    <sys:String>Expiré</sys:String>
                                    <sys:String>EnAttente</sys:String>
                                </x:Array>
                            </syncfusion:GridComboBoxColumn.ItemsSource>
                        </syncfusion:GridComboBoxColumn>

                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <!-- BARRE BAS -->
                <DockPanel Grid.Row="3" LastChildFill="True" Margin="0,8,0,0">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left"
                                Margin="0,0,12,0">
                        <TextBlock Text="Éléments par page"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="CboElementsParPage"
                                  Width="70" Height="28"
                                  VerticalAlignment="Center"
                                  SelectionChanged="CboElementsParPage_SelectionChanged"/>
                    </StackPanel>

                    <syncfusion:SfDataPager x:Name="DataPager"
                                            PageSize="10"
                                            NumericButtonCount="5"
                                            UseOnDemandPaging="False"
                                            PageIndexChanged="DataPager_PageIndexChanged"
                                            DockPanel.Dock="Right"/>

                    <TextBlock x:Name="TxtPagination"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#4B5563"
                               FontSize="13"/>
                </DockPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>